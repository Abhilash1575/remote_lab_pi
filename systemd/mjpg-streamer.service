[Unit]
Description=MJPG Streamer
After=network.target

[Service]
Type=simple
User=%i
ExecStart=/usr/local/bin/ustreamer --device /dev/video0 --resolution 1280x720 --format MJPEG --encoder m2m-video --quality 100 --desired-fps 30 --host 0.0.0.0 --port 8080
Restart=always

[Install]
WantedBy=multi-user.target
